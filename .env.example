# Скопируйте в .env.local для локальной разработки с `vercel dev`
# На Vercel задайте те же переменные в Settings → Environment Variables

# Секрет синхронизации (один и тот же на сервере и в клиенте)
CRM_SYNC_SECRET=замените-на-длинную-случайную-строку
VITE_CRM_SYNC_SECRET=замените-на-длинную-случайную-строку

# Postgres подставляется автоматически после создания Vercel Postgres / Neon:
# POSTGRES_URL=...
